% --------------------------------------------------------
% PDF/A COMPLIANCE - Load pdfx package for PDF/A-2b conversion
% This must be loaded BEFORE hyperref for proper PDF/A compliance
% --------------------------------------------------------
\PassOptionsToPackage{% 
  , bookmarksnumbered=true%
  , breaklinks=true%
  , colorlinks=true%
  , pdfdisplaydoctitle=true%
  , unicode=true%
}{hyperref}%
\RequirePackage[a-2b,pdf17]{pdfx}

%%%%% Configure multilingual language support
\RequirePackage{csquotes}
\RequirePackage[english]{babel}	% Support for bilingual documents
\RequirePackage{translator} % Support month name translations for pgfcalendar

% --------------------------------------------------------
%% CHECK IF USING LUALATEX OR XELATEX
% --------------------------------------------------------
\newcommand{\ifxeorlua}{\ifboolexpr{bool{luatex} or bool{xetex}}}
\newcommand{\ifxetexorluatex}{\iftutex}


\ifxetexorluatex
  \RequirePackage[no-math]{fontspec}%
  \defaultfontfeatures{Ligatures=TeX}
  \setsansfont{Verdana}[
    BoldFont       = Verdana Bold,
    ItalicFont     = Verdana Italic,
    BoldItalicFont = Verdana Bold Italic
  ]%
  \renewcommand{\familydefault}{\sfdefault}%
\else
  \RequirePackage[T1]{fontenc}%
  \RequirePackage[utf8]{inputenc}%
  \IfFileExists{verdana.sty}{%
    \RequirePackage{verdana}%
  }{%
    \RequirePackage[scaled]{helvet}%
  }%
  \renewcommand{\familydefault}{\sfdefault}%
\fi

%%%%% Fine tuning of typesetting
\ifxetexorluatex
  \RequirePackage[babel=true,final,tracking=false,
                  kerning=false,spacing=false,
                  factor=1100,stretch=10,shrink=10]{microtype}
\else
  \RequirePackage[babel=true,activate={true,nocompatibility},
                  final,tracking=true,kerning=true,spacing=true,
                  factor=1100,stretch=10,shrink=10]{microtype}
\fi


%% Date and Calendar Utility Macros
